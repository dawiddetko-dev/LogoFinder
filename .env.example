# Azure subscription and deployment
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-logo-verification-poc
AZURE_LOCATION=westeurope

# Azure AI Content Understanding
CONTENT_UNDERSTANDING_ENDPOINT=https://<content-understanding-name>.cognitiveservices.azure.com/
CONTENT_UNDERSTANDING_API_KEY=
CONTENT_UNDERSTANDING_ANALYZER_ID=logo_detector_analyzer
CONTENT_UNDERSTANDING_API_VERSION=2025-11-01

# Verification rules
DETECTION_THRESHOLD=0.65
MIN_MATCHES_REQUIRED=1

# Reference matcher fallback (uses images from reference folder)
ENABLE_REFERENCE_LOGO_MATCHER=true
REFERENCE_MATCH_MIN_GOOD_MATCHES=10
REFERENCE_MATCH_RATIO_TEST_THRESHOLD=0.8
REFERENCE_MATCH_TEMPLATE_THRESHOLD=0.72
REFERENCE_MATCH_MIN_INLIERS=8
REFERENCE_MATCH_MIN_INLIER_RATIO=0.4

# Local data folders
REFERENCE_LOGOS_DIR=data/logos_reference
PRODUCT_IMAGES_DIR=data/products_to_verify
OUTPUT_REPORT_PATH=outputs/verification_report.json
